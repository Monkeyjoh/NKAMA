# ─────────────────────────────────────────────────────────────
# NKAMA — Variables d'environnement
# Copier ce fichier en `.env` et renseigner les valeurs Supabase
# (laisser vide tant que Supabase n'est pas connecté).
# ─────────────────────────────────────────────────────────────

# URL du projet Supabase (ex. https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Clé publique "anon" du projet Supabase
VITE_SUPABASE_ANON_KEY=
